<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FB"
    tools:ignore="HardcodedText,Autofill,ButtonBarButtonStyle,MissingPrefix"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1D4ED8"
        android:padding="20dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Electric Bill Estimator"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="14dp"
                android:layout_marginBottom="18dp"
                android:elevation="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fill in your details to calculate monthly electricity bill 💡"
                    android:textColor="#475569"
                    android:textSize="14sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Month"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_marginBottom="6dp"/>

            <Spinner
                android:id="@+id/spinnerMonth"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ Electricity Usage (kWh)"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etUnits"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#FFFFFF"
                android:hint="Enter units (1 - 1000)"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏷️ Rebate"
                android:textStyle="bold"
                android:textColor="#0F172A"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Adjust discount"
                    android:textColor="#64748B"/>

                <TextView
                    android:id="@+id/tvRebateValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#2563EB"
                    android:textStyle="bold"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekBarRebate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="5"
                android:progress="0"
                android:layout_marginBottom="18dp"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CALCULATE &amp; SAVE ⚡"
                android:textStyle="bold"
                android:backgroundTint="#2563EB"
                android:textColor="#FFFFFF"
                android:elevation="4dp"
                android:layout_marginBottom="18dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Result"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvTotalCharges"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Charges: RM 0.00"
                    android:textColor="#334155"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvFinalCost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Final Cost: RM 0.00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:elevation="8dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnHistory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="History"
            android:backgroundTint="#EFF6FF"
            android:textColor="#1D4ED8"
            android:elevation="2dp"
            android:layout_marginEnd="4dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAbout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="About"
            android:backgroundTint="#EFF6FF"
            android:textColor="#1D4ED8"
            android:elevation="2dp"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

</LinearLayout>